// Table-driven parity suite: for each model name, load tests/data/<name>.full.json
// and tests/data/parity/<name>.json (generated by scripts/gen_parity.py) and
// assert that encode (add_special_tokens=false) matches Python `tokenizers`
// token-for-token. Missing fixtures are skipped gracefully.
//
// Covers every model family the port implements: byte-level BPE (gpt2/roberta),
// byte_fallback BPE (llama), WordPiece cased+uncased (bert/bert_cased/
// distilbert), Unigram/SentencePiece (t5/albert/xlm_roberta), and modern LLMs
// using the Qwen/Llama-3 Split pattern (Qwen2.5/Qwen3/DeepSeek/Phi-3), plus
// modern encoder/embedding tokenizers (ModernBERT, MiniLM, BGE, Jina, Nomic).

///|
let parity_models : Array[String] = [
  "gpt2", "roberta", "llama", "bert", "bert_cased", "distilbert", "t5", "albert",
  "xlm_roberta", "Qwen2.5", "qwen3", "deepseek", "phi3", "mistral", "falcon", "starcoder2",
  "gptneox", "clip", "deberta", "llama3_2", "phi4_mini", "deepseek_r1_qwen", "deepseek_v3_2",
  "gpt_oss", "glm4_5", "granite4", "qwen3_coder", "qwen3_vl", "bge_m3", "e5_multilingual",
  "modernbert", "gte_modernbert", "minilm", "bge_large_en", "jina_v3", "nomic_embed",
  "e5_small", "mxbai_embed_large", "smollm2",
]

// Run parity for one model; returns (ran, mismatches).

///|
fn run_parity(name : String) -> (Bool, Int) raise {
  let model_path = "tests/data/\{name}.full.json"
  let parity_path = "tests/data/parity/\{name}.json"
  guard load_text(model_path) is Some(model_json) else { return (false, 0) }
  guard load_text(parity_path) is Some(parity_json) else { return (false, 0) }
  let tok = @tokenizer.Tokenizer::from_str(model_json)
  let root = @types.as_object(@json.parse(parity_json), "parity")
  let cases = match root.get("cases") {
    Some(Array(a)) => a
    _ => return (true, 0)
  }
  let mut mism = 0
  for case in cases {
    let obj = @types.as_object(case, "case")
    let text = @types.get_str(obj, "text", default="")
    let want = parse_int_array(obj, "ids")
    let got = tok.encode(text, add_special_tokens=false).ids
    if got != want {
      @test.assert_eq((name, text, got), (name, text, want))
      mism = mism + 1
    }
  }
  (true, mism)
}

///|
test "parity: encode matches python tokenizers across models" {
  for name in parity_models {
    let (ran, mism) = run_parity(name)
    if ran {
      @test.assert_eq((name, mism), (name, 0))
    }
  }
}
