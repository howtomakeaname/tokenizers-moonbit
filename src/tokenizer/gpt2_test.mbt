// Cross-check the GPT-2 byte-level BPE encoder against expected outputs
// generated by the Python `tokenizers` library (scripts/gen_expected.py).
//
// Fixtures (tests/data/gpt2.full.json, gpt2_expected.json) are loaded from disk
// via from_file / x.fs; this test runs on native and js. The large model file
// is git-ignored, so the test is skipped gracefully when it is absent.

///|
fn load_text(path : String) -> String? {
  if @fs.path_exists(path) {
    Some(@fs.read_file_to_string(path)) catch {
      _ => None
    }
  } else {
    None
  }
}

///|
test "gpt2 splits the <|endoftext|> special token out of text" {
  guard load_text("tests/data/gpt2.full.json") is Some(model_json) else {
    return
  }
  let tok = Tokenizer::from_str(model_json)
  // Matches Python tokenizers: <|endoftext|> -> id 50256, recognized inline.
  let enc = tok.encode("hello<|endoftext|>world", add_special_tokens=false)
  @test.assert_eq(enc.ids, [31373, 50256, 6894])
  @test.assert_eq(enc.tokens, ["hello", "<|endoftext|>", "world"])
}

///|
test "gpt2 encode matches python tokenizers" {
  let model_path = "tests/data/gpt2.full.json"
  let expected_path = "tests/data/gpt2_expected.json"
  guard load_text(model_path) is Some(model_json) else { return }
  guard load_text(expected_path) is Some(exp_json) else { return }
  let tok = Tokenizer::from_str(model_json)
  let cases = @types.as_array(@json.parse(exp_json), "expected")
  for case in cases {
    let obj = @types.as_object(case, "case")
    let text = @types.get_str(obj, "text", default="")
    let want_ids = parse_int_array(obj, "ids")
    let enc = tok.encode(text, add_special_tokens=false)
    @test.assert_eq(enc.ids, want_ids)
    // decode round-trip: ids -> text should match python's decoded output
    let want_decoded = @types.get_str(obj, "decoded", default="")
    @test.assert_eq(
      tok.decode(enc.ids, skip_special_tokens=false),
      want_decoded,
    )
  }
}

///|
fn parse_int_array(obj : Map[String, Json], key : String) -> Array[Int] {
  let out : Array[Int] = []
  match obj.get(key) {
    Some(Array(a)) =>
      for x in a {
        match x {
          Number(n, ..) => out.push(n.to_int())
          _ => ()
        }
      }
    _ => ()
  }
  out
}
